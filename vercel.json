{
  "rewrites": [
    { "source": "/api/tracker", "destination": "/api/tracker" },
    { "source": "/api/whatsapp-notify", "destination": "/api/tracker" }
  ],
  "headers": [
    {
      "source": "/(.*\\.(webp|png|ico|webmanifest))",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
